{% extends 'base.html.twig' %}

{% block title %}Tableau de Bord Admin{% endblock %}

{% block body %}
<div class="container-fluid mt-5">
    <div class="row">
        <!-- En-tête -->
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h2">
                    <i class="fa fa-chart-line"></i> Tableau de Bord Administrateur
                </h1>
                <div>
                    <span class="me-3 text-muted">Bienvenue, <strong>{{ app.user.nomClient ?? 'Admin' }}</strong></span>
                    <a href="{{ path('logout') }}" class="btn btn-danger">
                        <i class="fa fa-sign-out"></i> Déconnexion
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Statistiques -->
        <div class="col-md-3 mb-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title text-muted">Clients</h5>
                    <h2 class="text-primary">{{ totalClients }}</h2>
                    <p class="card-text">Total des clients</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title text-muted">Messages</h5>
                    <h2 class="text-success">{{ totalMessages }}</h2>
                    <p class="card-text">Messages en attente</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title text-muted">Produits</h5>
                    <h2 class="text-info">{{ totalProduits }}</h2>
                    <p class="card-text">Total des produits</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title text-muted">Commandes</h5>
                    <h2 class="text-warning">0</h2>
                    <p class="card-text">Commandes récentes</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <!-- Menu d'administration -->
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fa fa-cog"></i> Gestion</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <a href="{{ path('app_chat_admin') }}" class="btn btn-outline-primary w-100">
                                <i class="fa fa-comments"></i> Gérer Chat
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a href="{{ path('app_chatbot_index') }}" class="btn btn-outline-info w-100">
                                <i class="fa fa-robot"></i> Chatbot IA
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a href="{{ path('app_categorie_vehicule_index') }}" class="btn btn-outline-success w-100">
                                <i class="fa fa-list"></i> Catégories
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a href="{{ path('app_produit_index')|default('#') }}" class="btn btn-outline-warning w-100">
                                <i class="fa fa-box"></i> Produits
                            </a>
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-md-6 mb-3">
                            <a href="{{ path('app_client_index')|default('#') }}" class="btn btn-outline-secondary w-100">
                                <i class="fa fa-users"></i> Clients
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Appels à l'action supplémentaires -->
    <div class="row mt-5">
        <div class="col-md-6">
            <div class="card border-left-info">
                <div class="card-body">
                    <h5 class="card-title">Conversations en attente</h5>
                    <p class="card-text text-muted">Consultez les clients qui ont besoin d'assistance.</p>
                    <a href="{{ path('app_chat_admin') }}" class="btn btn-sm btn-info">Voir les conversations</a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-left-success">
                <div class="card-body">
                    <h5 class="card-title">Gestion des Produits</h5>
                    <p class="card-text text-muted">Ajoutez, modifiez ou supprimez des produits.</p>
                    <a href="{{ path('app_produit_index')|default('#') }}" class="btn btn-sm btn-success">Gérer les produits</a>
                </div>
            </div>
        </div>
    </div>

    <style>
        .border-left-info {
            border-left: 4px solid #17a2b8;
        }
        .border-left-success {
            border-left: 4px solid #28a745;
        }
    </style>
</div>



      </div><!-- /.container-fluid -->
    </section>
    <!-- /.content -->
  </div>
  <!-- /.content-wrapper -->
{% endblock %}
  