{% extends 'admin/base_admin.html.twig' %}

{% block title %}Conversation — Admin New Day{% endblock %}

{% block admin_content %}

<div class="admin-header">
    <div style="display:flex;align-items:center;gap:16px;">
        <a href="{{ path('app_admin_messages') }}" class="btn btn-dark btn-sm">← Retour</a>
        <div>
            <h1 style="font-size:1.3rem;">{{ message_racine.produit.titre }}</h1>
            <p style="color:var(--color-text-muted);font-size:13px;margin-top:2px;">
                Client : {{ message_racine.expediteur.nomComplet }} · {{ message_racine.expediteur.email }}
            </p>
        </div>
    </div>
</div>

{# ── Produit ─────────────────────────────────────────────── #}
<a href="{{ path('app_produit_detail', {id: message_racine.produit.id}) }}" target="_blank"
   style="display:flex;align-items:center;gap:16px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;padding:16px;margin-bottom:32px;text-decoration:none;color:inherit;">
    {% set img = message_racine.produit.imagePrincipale %}
    {% if img %}
    <div style="width:60px;height:48px;border-radius:4px;overflow:hidden;flex-shrink:0;">
        <img src="{{ asset(img.urlPublique) }}" alt="" style="width:100%;height:100%;object-fit:cover;">
    </div>
    {% endif %}
    <div>
        <div style="font-size:12px;color:var(--color-gold);">{{ message_racine.produit.categorie.nom }}</div>
        <div style="font-weight:600;">{{ message_racine.produit.titre }}</div>
    </div>
    <span style="margin-left:auto;color:var(--color-gold);"><i class="fa-solid fa-arrow-up-right-from-square"></i> Voir sur le site</span>
</a>

{# ── Fil ─────────────────────────────────────────────────── #}
<div class="message-thread" style="margin-bottom:32px;max-width:700px;">
    {% for msg in fil %}
    {% set isAdmin = 'ROLE_ADMIN' in msg.expediteur.roles %}
    <div class="message-bubble {{ isAdmin ? 'mine' : 'theirs' }}">
        <div style="font-size:12px;color:{{ isAdmin ? 'var(--color-gold)' : 'var(--color-text-muted)' }};font-weight:600;margin-bottom:8px;">
            {{ isAdmin ? '🏢 Admin — ' ~ msg.expediteur.nomComplet : '👤 ' ~ msg.expediteur.nomComplet }}
        </div>
        <div style="font-size:14px;line-height:1.7;">{{ msg.contenu|nl2br }}</div>
        <div class="message-meta">{{ msg.createdAt|date('d/m/Y à H:i') }}</div>
    </div>
    {% endfor %}
</div>

{# ── Répondre ────────────────────────────────────────────── #}
<div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;padding:28px;max-width:700px;">
    <h3 style="font-size:16px;margin-bottom:20px;">Répondre au client</h3>
    <form method="POST">
        <div class="form-group">
            <textarea name="contenu" class="form-control" rows="5"
                      placeholder="Votre réponse..." required></textarea>
        </div>
        <button type="submit" class="btn btn-gold">Envoyer la réponse</button>
    </form>
</div>

{% endblock %}
