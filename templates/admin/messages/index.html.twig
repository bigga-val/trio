{% extends 'admin/base_admin.html.twig' %}

{% block title %}Messages — Admin New Day{% endblock %}

{% block admin_content %}

<div class="admin-header">
    <div>
        <h1>Messages clients</h1>
        <p style="color:var(--color-text-muted);font-size:14px;margin-top:4px;">{{ messages|length }} conversation{{ messages|length > 1 ? 's' : '' }}</p>
    </div>
</div>

{% if messages is not empty %}
<div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;overflow:hidden;">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Client</th>
                <th>Produit</th>
                <th>Message</th>
                <th>Réponses</th>
                <th>Date</th>
                <th>Statut</th>
                <th style="width:100px;">Action</th>
            </tr>
        </thead>
        <tbody>
            {% for msg in messages %}
            <tr style="{{ not msg.lu ? 'background:rgba(201,168,76,0.03)' : '' }}">
                <td>
                    <div style="font-weight:600;font-size:14px;">{{ msg.expediteur.nomComplet }}</div>
                    <div style="font-size:12px;color:var(--color-text-muted);">{{ msg.expediteur.email }}</div>
                </td>
                <td style="font-size:13px;max-width:200px;">
                    <div style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ msg.produit.titre }}</div>
                </td>
                <td style="font-size:13px;color:var(--color-text-muted);max-width:250px;">
                    <div style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                        {{ msg.contenu|slice(0, 80) }}{% if msg.contenu|length > 80 %}…{% endif %}
                    </div>
                </td>
                <td style="text-align:center;">
                    <span class="badge badge-gray">{{ msg.reponses|length }}</span>
                </td>
                <td style="font-size:13px;color:var(--color-text-muted);">
                    {{ msg.createdAt|date('d/m/Y') }}
                </td>
                <td>
                    {% if not msg.lu %}
                    <span class="badge badge-gold">Non lu</span>
                    {% else %}
                    <span class="badge badge-gray">Lu</span>
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('app_admin_message_detail', {id: msg.id}) }}" class="btn btn-dark btn-sm">
                        Ouvrir →
                    </a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% else %}
<div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;padding:80px;text-align:center;">
    <div style="font-size:48px;margin-bottom:16px;">💬</div>
    <p style="color:var(--color-text-muted);">Aucun message pour l'instant.</p>
</div>
{% endif %}

{% endblock %}
