<!-- Vesitable Shop Start-->
<div class="container-fluid vesitable py-5">
    <div class="container py-5">
        <h1 class="mb-0">Autres produits </h1>
        <div class="owl-carousel vegetable-carousel justify-content-center">

          {% for sli in sliderProd %}
            <div class="border border-primary rounded position-relative vesitable-item">
                <div class="vesitable-img">
                    <img src="{{sli.imageProduit}}" class="img-fluid w-100 rounded-top" alt="">
                </div>
                <div class="text-white bg-primary px-3 py-1 rounded position-absolute" style="top: 10px; right: 10px;">{{sli.localisation}}</div>
                <div class="p-4 rounded-bottom">
                    <h4>{{sli.nomProduit}}</h4>
                    <p>{{ sli.descrition}}</p>
                    <div class="d-flex justify-content-between flex-lg-wrap">
                        <p class="text-dark fs-5 fw-bold mb-0">{{ sli.prixProduit }}</p>
                        <a href="{{ path('app_detail', {'id': sli.id}) }}" class="btn border border-secondary rounded-pill px-3 text-primary"><i class="fa fa-shopping-bag me-2 text-primary"></i>Detail</a>
                    </div>
                </div>
            </div>
           {% endfor %}
        </div>
    </div>
</div>
<!-- Vesitable Shop End -->
