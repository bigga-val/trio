{% extends 'compte/base_compte.html.twig' %}

{% block title %}Mon profil — New Day Groupe SARL{% endblock %}

{% block compte_content %}

<div style="margin-bottom:40px;">
    <span style="color:var(--color-gold);font-size:12px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;">Espace client</span>
    <h1 style="font-size:2rem;margin-top:8px;">Mon profil</h1>
</div>

<div style="display:flex;flex-direction:column;gap:32px;max-width:600px;">

    {# ── Infos personnelles ──────────────────────────────────── #}
    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:10px;padding:32px;">
        <h2 style="font-size:1.1rem;margin-bottom:24px;padding-bottom:16px;border-bottom:1px solid var(--color-border);">
            <i class="fa-solid fa-user" style="color:var(--color-gold);"></i> Informations personnelles
        </h2>

        <form method="POST">
            <input type="hidden" name="_action" value="infos">

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div class="form-group">
                    <label class="form-label" for="prenom">Prénom</label>
                    <input type="text" name="prenom" id="prenom" class="form-control"
                           value="{{ app.user.prenom }}" required>
                    {% if errors.prenom is defined %}
                    <div class="form-error">{{ errors.prenom }}</div>
                    {% endif %}
                </div>

                <div class="form-group">
                    <label class="form-label" for="nom">Nom</label>
                    <input type="text" name="nom" id="nom" class="form-control"
                           value="{{ app.user.nom }}" required>
                    {% if errors.nom is defined %}
                    <div class="form-error">{{ errors.nom }}</div>
                    {% endif %}
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Adresse email</label>
                <input type="email" class="form-control" value="{{ app.user.email }}"
                       disabled style="opacity:.6;cursor:not-allowed;">
                <div style="font-size:12px;color:var(--color-text-muted);margin-top:6px;">L'email ne peut pas être modifié.</div>
            </div>

            <div class="form-group" style="margin-bottom:28px;">
                <label class="form-label" for="telephone">Téléphone</label>
                <input type="tel" name="telephone" id="telephone" class="form-control"
                       value="{{ app.user.telephone ?? '' }}" placeholder="+243 970 000 000">
            </div>

            <button type="submit" class="btn btn-gold">Enregistrer les modifications</button>
        </form>
    </div>

    {# ── Changer mot de passe ────────────────────────────────── #}
    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:10px;padding:32px;">
        <h2 style="font-size:1.1rem;margin-bottom:24px;padding-bottom:16px;border-bottom:1px solid var(--color-border);">
            <i class="fa-solid fa-lock" style="color:var(--color-gold);"></i> Modifier le mot de passe
        </h2>

        <form method="POST">
            <input type="hidden" name="_action" value="password">

            <div class="form-group">
                <label class="form-label" for="password_actuel">Mot de passe actuel</label>
                <input type="password" name="password_actuel" id="password_actuel"
                       class="form-control" placeholder="••••••••" required>
                {% if errors.password_actuel is defined %}
                <div class="form-error">{{ errors.password_actuel }}</div>
                {% endif %}
            </div>

            <div class="form-group">
                <label class="form-label" for="password_nouveau">Nouveau mot de passe</label>
                <input type="password" name="password_nouveau" id="password_nouveau"
                       class="form-control" placeholder="Minimum 6 caractères" required>
                {% if errors.password_nouveau is defined %}
                <div class="form-error">{{ errors.password_nouveau }}</div>
                {% endif %}
            </div>

            <div class="form-group" style="margin-bottom:28px;">
                <label class="form-label" for="password_confirmer">Confirmer le nouveau mot de passe</label>
                <input type="password" name="password_confirmer" id="password_confirmer"
                       class="form-control" placeholder="Répétez le nouveau mot de passe" required>
                {% if errors.password_confirmer is defined %}
                <div class="form-error">{{ errors.password_confirmer }}</div>
                {% endif %}
            </div>

            <button type="submit" class="btn btn-outline">Changer le mot de passe</button>
        </form>
    </div>

    {# ── Infos compte ────────────────────────────────────────── #}
    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:10px;padding:24px;">
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
            <div>
                <div style="font-size:13px;color:var(--color-text-muted);">Membre depuis</div>
                <div style="font-weight:600;">{{ app.user.createdAt|date('d MMMM Y')|capitalize }}</div>
            </div>
            <div>
                <div style="font-size:13px;color:var(--color-text-muted);">Statut</div>
                <span class="badge badge-green">Actif</span>
            </div>
        </div>
    </div>

</div>

{% endblock %}
