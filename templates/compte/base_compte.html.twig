{% extends 'base.html.twig' %}

{% block body %}
<div style="padding-top:80px;min-height:100vh;background:var(--color-bg);">
<div class="container">
<div class="compte-layout">

    {# ── Sidebar ─────────────────────────────────────────────── #}
    <aside class="compte-sidebar">
        <div style="padding:24px 20px;border-bottom:1px solid var(--color-border);margin-bottom:8px;">
            <div style="width:48px;height:48px;border-radius:50%;background:rgba(201,168,76,0.15);border:1px solid rgba(201,168,76,0.3);display:flex;align-items:center;justify-content:center;font-size:20px;color:var(--color-gold);margin-bottom:12px;">
                {{ app.user.nomComplet|slice(0,1)|upper }}
            </div>
            <div style="font-weight:600;font-size:15px;">{{ app.user.nomComplet }}</div>
            <div style="font-size:12px;color:var(--color-gold);margin-top:2px;">@{{ app.user.username }}</div>
            <div style="font-size:11px;color:var(--color-text-muted);margin-top:1px;">{{ app.user.email }}</div>
        </div>

        <nav>
            <ul class="compte-nav">
                <li>
                    <a href="{{ path('app_compte_dashboard') }}"
                       class="{{ app.request.attributes.get('_route') == 'app_compte_dashboard' ? 'active' : '' }}">
                        <i class="fa-solid fa-gauge fa-fw"></i> Tableau de bord
                    </a>
                </li>
                <li>
                    <a href="{{ path('app_compte_messages') }}"
                       class="{{ app.request.attributes.get('_route') starts with 'app_compte_message' ? 'active' : '' }}">
                        <i class="fa-solid fa-message fa-fw"></i> Mes messages
                    </a>
                </li>
                <li>
                    <a href="{{ path('app_compte_profil') }}"
                       class="{{ app.request.attributes.get('_route') == 'app_compte_profil' ? 'active' : '' }}">
                        <i class="fa-solid fa-user fa-fw"></i> Mon profil
                    </a>
                </li>
                <li>
                    <a href="{{ path('app_boutique') }}">
                        <i class="fa-solid fa-store fa-fw"></i> Retour boutique
                    </a>
                </li>
                <li style="margin-top:8px;border-top:1px solid var(--color-border);padding-top:8px;">
                    <a href="{{ path('app_deconnexion') }}" style="color:var(--color-text-muted);">
                        <i class="fa-solid fa-right-from-bracket fa-fw"></i> Déconnexion
                    </a>
                </li>
            </ul>
        </nav>
    </aside>

    {# ── Contenu ─────────────────────────────────────────────── #}
    <main style="padding:40px 0 80px;">
        {% block compte_content %}{% endblock %}
    </main>

</div>
</div>
</div>
{% endblock %}
