{% extends 'compte/base_compte.html.twig' %}

{% block title %}Mon espace — New Day Groupe SARL{% endblock %}

{% block compte_content %}

<div style="margin-bottom:40px;">
    <span style="color:var(--color-gold);font-size:12px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;">Espace client</span>
    <h1 style="font-size:2rem;margin-top:8px;">Bonjour, {{ app.user.prenom }} 👋</h1>
    <p style="color:var(--color-text-muted);margin-top:8px;">Bienvenue dans votre espace personnel New Day Groupe.</p>
</div>

{# ── Stats ───────────────────────────────────────────────── #}
<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:48px;">
    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;padding:28px;">
        <div style="font-family:var(--font-title);font-size:2.4rem;color:var(--color-gold);line-height:1;">{{ messages|length }}</div>
        <div style="font-size:13px;color:var(--color-text-muted);margin-top:6px;text-transform:uppercase;letter-spacing:.08em;">Conversations</div>
    </div>
    <div style="background:var(--color-surface);border:1px solid {{ non_lues > 0 ? 'var(--color-gold)' : 'var(--color-border)' }};border-radius:8px;padding:28px;">
        <div style="font-family:var(--font-title);font-size:2.4rem;color:{{ non_lues > 0 ? 'var(--color-gold)' : 'var(--color-text-muted)' }};line-height:1;">{{ non_lues }}</div>
        <div style="font-size:13px;color:var(--color-text-muted);margin-top:6px;text-transform:uppercase;letter-spacing:.08em;">Réponses non lues</div>
    </div>
    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;padding:28px;">
        <div style="font-family:var(--font-title);font-size:2.4rem;color:var(--color-gold);line-height:1;">
            {{ app.user.createdAt|date('Y') }}
        </div>
        <div style="font-size:13px;color:var(--color-text-muted);margin-top:6px;text-transform:uppercase;letter-spacing:.08em;">Membre depuis</div>
    </div>
</div>

{# ── Derniers messages ───────────────────────────────────── #}
<div>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
        <h2 style="font-size:1.3rem;">Mes dernières conversations</h2>
        <a href="{{ path('app_compte_messages') }}" class="btn btn-outline btn-sm">Voir tout</a>
    </div>

    {% if messages is not empty %}
    <div style="display:flex;flex-direction:column;gap:12px;">
        {% for msg in messages|slice(0, 5) %}
        <a href="{{ path('app_compte_message_detail', {id: msg.id}) }}"
           style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;padding:20px;display:flex;align-items:center;gap:16px;transition:border-color .3s;text-decoration:none;color:inherit;"
           onmouseover="this.style.borderColor='var(--color-gold)'"
           onmouseout="this.style.borderColor='var(--color-border)'">

            <div style="width:44px;height:44px;border-radius:50%;background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.2);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:18px;">
                🚗
            </div>

            <div style="flex:1;min-width:0;">
                <div style="font-weight:600;font-size:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                    {{ msg.produit.titre }}
                </div>
                <div style="font-size:13px;color:var(--color-text-muted);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                    {{ msg.contenu|slice(0, 80) }}{% if msg.contenu|length > 80 %}…{% endif %}
                </div>
            </div>

            <div style="text-align:right;flex-shrink:0;">
                <div style="font-size:12px;color:var(--color-text-muted);">{{ msg.createdAt|date('d/m/Y') }}</div>
                {% set repNonLues = msg.reponses|filter(r => not r.lu and r.expediteur != app.user)|length %}
                {% if repNonLues > 0 %}
                <span class="badge badge-gold" style="margin-top:4px;">{{ repNonLues }} nouvelle{{ repNonLues > 1 ? 's' : '' }}</span>
                {% endif %}
            </div>
        </a>
        {% endfor %}
    </div>
    {% else %}
    <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;padding:48px;text-align:center;">
        <div style="font-size:48px;margin-bottom:16px;">💬</div>
        <p style="color:var(--color-text-muted);margin-bottom:24px;">Vous n'avez pas encore de conversation.</p>
        <a href="{{ path('app_boutique') }}" class="btn btn-gold">Parcourir les produits</a>
    </div>
    {% endif %}
</div>

{% endblock %}
