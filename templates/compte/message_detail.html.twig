{% extends 'compte/base_compte.html.twig' %}

{% block title %}Conversation — {{ message_racine.produit.titre }}{% endblock %}

{% block compte_content %}

{# ── En-tête ─────────────────────────────────────────────── #}
<div style="display:flex;align-items:center;gap:16px;margin-bottom:40px;">
    <a href="{{ path('app_compte_messages') }}" class="btn btn-dark btn-sm">← Retour</a>
    <div>
        <span style="color:var(--color-gold);font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;">Conversation</span>
        <h1 style="font-size:1.5rem;margin-top:4px;">{{ message_racine.produit.titre }}</h1>
    </div>
</div>

{# ── Produit concerné ────────────────────────────────────── #}
<a href="{{ path('app_produit_detail', {id: message_racine.produit.id}) }}"
   style="display:flex;align-items:center;gap:16px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;padding:16px 20px;margin-bottom:40px;text-decoration:none;color:inherit;transition:border-color .3s;"
   onmouseover="this.style.borderColor='var(--color-gold)'"
   onmouseout="this.style.borderColor='var(--color-border)'">
    {% set img = message_racine.produit.imagePrincipale %}
    {% if img %}
    <div style="width:60px;height:48px;border-radius:4px;overflow:hidden;flex-shrink:0;">
        <img src="{{ asset(img.urlPublique) }}" alt="" style="width:100%;height:100%;object-fit:cover;">
    </div>
    {% endif %}
    <div>
        <div style="font-size:12px;color:var(--color-gold);margin-bottom:2px;">{{ message_racine.produit.categorie.nom }}</div>
        <div style="font-weight:600;">{{ message_racine.produit.titre }}</div>
        {% if message_racine.produit.prix %}
        <div style="font-size:13px;color:var(--color-text-muted);">$ {{ message_racine.produit.prix|number_format(0, ',', ' ') }}</div>
        {% endif %}
    </div>
    <span style="margin-left:auto;color:var(--color-gold);">Voir →</span>
</a>

{# ── Fil de messages ─────────────────────────────────────── #}
<div class="message-thread" style="margin-bottom:40px;">
    {% for msg in fil %}
    {% set isMine = msg.expediteur == app.user %}
    <div class="message-bubble {{ isMine ? 'mine' : 'theirs' }}">
        {% if not isMine %}
        <div style="font-size:12px;color:var(--color-gold);font-weight:600;margin-bottom:8px;">
            🏢 New Day Groupe — Admin
        </div>
        {% endif %}
        <div style="font-size:14px;line-height:1.7;">{{ msg.contenu|nl2br }}</div>
        <div class="message-meta">
            {{ isMine ? 'Vous' : 'Admin' }} · {{ msg.createdAt|date('d/m/Y à H:i') }}
        </div>
    </div>
    {% endfor %}
</div>

{# ── Formulaire de réponse ───────────────────────────────── #}
<div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;padding:28px;">
    <h3 style="font-size:16px;margin-bottom:20px;">Répondre</h3>
    <form method="POST">
        <div class="form-group">
            <textarea name="contenu" class="form-control" rows="4"
                      placeholder="Votre message..." required></textarea>
        </div>
        <button type="submit" class="btn btn-gold">Envoyer</button>
    </form>
</div>

{% endblock %}

{% block javascripts %}
<script>
// Scroll vers le bas du fil de messages au chargement
(function() {
    var thread = document.querySelector('.message-thread');
    if (thread) thread.scrollIntoView({ behavior: 'smooth', block: 'end' });
})();
</script>
{% endblock %}
