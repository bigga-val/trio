
{% include "extensions/navbarTab.html.twig" %}

<div class="content-wrapper">
    <section class="content">
          <div class="container-fluid">
            <div class="row">
              <!-- left column -->
              <div class="col-md-2">
              </div>
              <div class="col-md-12">
                <!-- general form elements -->
                <div class="card card-primary">
                  {# <div class="card-header">
                    <h3 class="card-title">Ajouter un service</h3>
                  </div> #}
                  <!-- /.card-header -->
                  <!-- form start -->
                 
                      <div class="row">
                         <div class="col-md-2"> 
                           
                         </div>
                          <div class="col-md-7"> <br>
                                <table class="table  bg-blue-sky"> 
                                           <thead>
                                            <tr>
                                                <th>Id</th>
                                                <th>NomCategorie</th>
                                                <th>Active</th>
                                                <th>actions</th>
                                            </tr>
                                        </thead>
                                        
                                        <tbody>
                                        {% for categorie_vehicule in categorie_vehicules %}
                                            <tr>
                                                <td>{{ categorie_vehicule.id }}</td>
                                                <td>{{ categorie_vehicule.nomCategorie }}</td>
                                                <td>{{ categorie_vehicule.active ? 'Yes' : 'No' }}</td>
                                                <td>
                                                    <a href="{{ path('app_categorie_vehicule_show', {'id': categorie_vehicule.id}) }}" class="btn btn-outline-info">show</a>
                                                    <a href="{{ path('app_categorie_vehicule_edit', {'id': categorie_vehicule.id}) }}" class="btn btn-outline-warning">edit</a>
                                                    <a href="{{ path('app_categorie_vehicule_new') }}" class="btn btn-outline-primary">Create new</a>
                                                </td>
                                            </tr>
                                        {% else %}
                                            <tr>
                                                <td colspan="4">no records found</td>
                                            </tr>
                                        {% endfor %}
                                        </tbody>
                                    </table>
                          </div>
                  </div>
                
                </div>
              </div>
           </div>
         </div>
    </section>
    </div>
