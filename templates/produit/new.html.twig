{% include "extensions/navbarTab.html.twig" %}

<div class="content-wrapper">
    <section class="content">
          <div class="container-fluid">
            <div class="row">
              <!-- left column -->
              <div class="col-md-2">
              </div>
              <div class="col-md-12">
                <!-- general form elements -->
                <div class="card card-primary">
                  <div class="card-header">
                    <h3 class="card-title">Ajouter un vehicule </h3>
                  </div>
                  <!-- /.card-header -->
                  <!-- form start -->
                  {{ form_start(form) }}
                  <div class="row">
                  
                       <div class="col-md-4"> 
                               <form>
                                      <div class="form-group"> <br>
                                        {{ form_widget(form.nomProduit, {'attr': {'class': 'form-control', 'required':'required'}}) }}
                                      </div>
                                      <div class="form-group">
                                        {{ form_widget(form.prixProduit, {'attr': {'class': 'form-control', 'required':'required'}}) }}
                                      </div>
                                      <div class="form-group">
                                         {{ form_widget(form.descrition, {'attr': {'class': 'form-control', 'required':'required'}}) }}
                                      </div>
                                      <button type="submit" class="btn btn-success btn-block">Enregistrer</button><br>
                         </div>
                          <div class="col-md-4"> <br>
                               <div class="form-group">
                                   {{ form_widget(form.localisation, {'attr': {'class': 'form-control'}}) }}
                              </div>
                              <div class="form-group">
                                   {{ form_widget(form.createdBy, {'attr': {'class': 'form-control'}}) }}
                              </div>
                              <div class="form-group">
                                 {{ form_widget(form.ceatedAt, {'attr': {'class': 'form-control'}}) }}
                              </div>
                               <a href="{{ path('app_produit_index') }}" class="btn btn-sm btn-primary btn-block">Liste des vehicules</a><br>
                       </div>
                       <div class="col-md-4">
                               <div class="form-group">
                                <label for="exampleInputPassword1">Categorie</label>
                                {{ form_widget(form.categorie, {'attr': {'class': 'form-control', 'required':'required'}}) }}
                              </div>
                              
                              <div class="form-group">
                                {# <label for="exampleInputPassword1">image </label> #}
                                  {{ form_widget(form.ImageProduit, {'attr': {'class': 'form-control'}}) }}
                              </div>
                              
                          </form>
                        </div>
                  </div>
                  
                  {{ form_end(form) }}
                </div>
              </div>
           </div>
         </div>
    </section>
    </div>
