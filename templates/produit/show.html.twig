{% extends 'base.html.twig' %}

{% block title %}Produit{% endblock %}

{% block body %}
    <div class="row">
        <div class="col-md-7">
            {# Main image (first of images or fallback to ImageProduit) #}
            {% set images = produit.getImages() is defined ? produit.getImages() : [] %}
            {% if images|length > 0 %}
                <img src="{{ images[0].getFilename() }}" class="img-fluid mb-3" alt="{{ produit.nomProduit }}">
            {% else %}
                <img src="{{ produit.ImageProduit }}" class="img-fluid mb-3" alt="{{ produit.nomProduit }}">
            {% endif %}

            {# Thumbnails gallery (small) #}
            <div class="d-flex flex-wrap gap-2 mb-3">
                {% for img in images %}
                    <div style="width:80px;">
                        <a href="{{ img.getFilename() }}" target="_blank">
                            <img src="{{ img.getFilename() }}" class="img-thumbnail" style="width:100%; height:60px; object-fit:cover;">
                        </a>
                    </div>
                {% endfor %}
            </div>

            {# Contact button placed under thumbnails #}
            <div class="mb-3">
                <a href="{{ path('app_client_new') }}" class="btn btn-outline-primary">Contactez le vendeur</a>
            </div>
        </div>

        <div class="col-md-5">
            <h1>{{ produit.nomProduit }}</h1>
            <p><strong>Prix :</strong> {{ produit.prixProduit }}</p>
            <p><strong>Localisation :</strong> {{ produit.localisation }}</p>
            <p><strong>Publié le :</strong> {{ produit.ceatedAt ? produit.ceatedAt|date('Y-m-d H:i:s') : '' }}</p>

            <div class="mt-3">
                <a href="{{ path('app_produit_index') }}" class="btn btn-secondary">Retour</a>
                <a href="{{ path('app_produit_edit', {'id': produit.id}) }}" class="btn btn-primary">Modifier</a>
                {{ include('produit/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
