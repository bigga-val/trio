{{ form_start(form) }}
                     <div class="row g-5">
                        <div class="col-md-12 col-lg-6 col-xl-8">
                            <h1 class="mb-4 text-center">CREER UN COMPTE CLIENT</h1>
                            <div class="row">
                                <div class="col-md-12 col-lg-6">
                                    <div class="form-item w-100">
                                        {{ form_widget(form.nomClient, {'attr': {'class': 'form-control', 'required':'required'}}) }}
                                    </div>
                                </div>
                                <div class="col-md-12 col-lg-6">
                                    <div class="form-item w-100">
                                        {{ form_widget(form.adresseClient, {'attr': {'class': 'form-control', 'required':'required'}}) }}
                                    </div>
                                </div>
                            </div>
                            <div class="form-item">
                                  <label class="form-label my-3"></label>
                                {{ form_widget(form.telephone, {'attr': {'class': 'form-control', 'required':'required'}}) }}
                            </div>
                            <div class="form-item">
                                <label class="form-label my-3"></label>
                                {{ form_widget(form.adresseEmail, {'attr': {'class': 'form-control', 'required':'required'}}) }}
                            </div>
                            <div class="form-item">
                                <label class="form-label my-3"> </label>
                                {{ form_widget(form.villeResidance, {'attr': {'class': 'form-control', 'required':'required'}}) }}
                            </div> <br>
                            <div class="form-item">
                                <label class="form-label my-3"> </label>
                                {{ form_widget(form.password, {'attr': {'class': 'form-control', 'required':'required'}}) }}
                            </div> <br>
                            <div class="row">
                                <div class="col-md-12 col-lg-6">
                                    <div class="form-item w-100">
                                         <button  type="submit" class="btn border border-secondary  rounded-pill px-3 text-primary  btn-block">{{ button_label|default('Save') }}</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                     </div>
                  
{{ form_end(form) }}
