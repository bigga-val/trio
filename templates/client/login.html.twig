
{{ include("extensions/navbar.html.twig") }}

{% block body %}
<div class="container py-5">
	<div class="row justify-content-center">
		<div class="col-md-6 col-lg-5">
			<div class="card shadow-sm">
				<div class="card-body">
					<h3 class="card-title mb-3 text-center">Connexion</h3>

					{% if error %}
						<div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert">
							<i class="fa fa-exclamation-circle me-2" style="font-size: 1.2em;"></i>
							<div>
								<strong>Erreur de connexion</strong>
								<p class="mb-0 mt-1">{{ error.messageKey|trans(error.messageData, 'security') }}</p>
								{% if error.message %}
									<small class="text-muted">{{ error.message }}</small>
								{% endif %}
							</div>
							<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
						</div>
					{% endif %}

					<form action="{{ path('app_login') }}" method="post" autocomplete="off">
						<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

						<div class="mb-3">
							<label for="inputEmail" class="form-label">Adresse e-mail</label>
							<input type="email" value="{{ adresseEmail|default('') }}" name="adresseEmail" id="inputEmail" class="form-control" required autofocus>
						</div>

						<div class="mb-3">
							<label for="inputPassword" class="form-label">Mot de passe</label>
							<input type="password" name="password" id="inputPassword" class="form-control" required>
						</div>

						<div class="mb-3 form-check">
							<input type="checkbox" name="_remember_me" id="rememberMe" class="form-check-input">
							<label for="rememberMe" class="form-check-label">Se souvenir de moi</label>
						</div>

						<div class="d-grid">
							<button type="submit" class="btn btn-primary">Se connecter</button>
						</div>
					</form>

					<div class="mt-3 text-center">
						<a href="{{ path('app_login')|default('#') }}">Mot de passe oublié ?</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

{% endblock %}
