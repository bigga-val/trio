
 {{ include("extensions/navbar.html.twig") }}

    <!-- Single Page Header start -->
    <div class="container-fluid page-header py-5">
        <h1 class="text-center text-white display-6">Compte Client</h1>
        <ol class="breadcrumb justify-content-center mb-0">
            <li class="breadcrumb-item"><a href="#">Home</a></li>
            <li class="breadcrumb-item"><a href="#">Pages</a></li>
            <li class="breadcrumb-item active text-white">Compte client</li>
        </ol>
    </div> <br>
    <!-- Single Page Header End -->
 

    <!-- Checkout Page Start -->
    <div class="row">
         
             <div class="col-md-3"> 
                 {# {{ include("extensions/categorie.html.twig") }} #}
             </div>
            <div class="col-md-8">
                {{form_start(form)}}
                   <form  method="post">
                     <div class="row g-5">
                        <div class="col-md-12 col-lg-6 col-xl-8">
                            <h1 class="mb-4 text-center">CREER UN COMPTE CLIENT</h1>
                            <div class="row">
                                <div class="col-md-12 col-lg-6">
                                    <div class="form-item w-100">
                                        {{ form_widget(form.nomClient, {'attr': {'class': 'form-control', 'required':'required'}}) }}
                                    </div>
                                </div>
                                <div class="col-md-12 col-lg-6">
                                    <div class="form-item w-100">
                                        {{ form_widget(form.adresseClient, {'attr': {'class': 'form-control', 'required':'required'}}) }}
                                    </div>
                                </div>
                            </div>
                            <div class="form-item">
                                  <label class="form-label my-3"></label>
                                {{ form_widget(form.telephone, {'attr': {'class': 'form-control', 'required':'required'}}) }}
                            </div>
                            <div class="form-item">
                                <label class="form-label my-3"></label>
                                {{ form_widget(form.adresseEmail, {'attr': {'class': 'form-control', 'required':'required'}}) }}
                            </div>
                            <div class="form-item">
                                <label class="form-label my-3"> </label>
                                {{ form_widget(form.villeResidance, {'attr': {'class': 'form-control', 'required':'required'}}) }}
                            </div> <br>
                            <div class="row">
                                <div class="col-md-12 col-lg-6">
                                    <div class="form-item w-100">
                                         <button  type="submit" class="btn border border-secondary  rounded-pill px-3 text-primary ">enregister vos données</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                     </div>
                   </form>
                 {{form_end(form)}}
                 <div class="col-md-12 col-lg-6">
                        <a href="{{path('app_client_index')}}" class="btn border border-secondary rounded-pill px-3 text-primary"><i class="fa fa-shopping-bag me-2 text-primary">  </i>j'ai un compte</a>
                </div>
            </div>
            <div class="col-md-2"> 
                 {# {{ include("extensions/categorie.html.twig") }} #}
            </div>
    </div> <br>
  {{ include("extensions/footer.html.twig") }}
    <!-- Checkout Page End -->